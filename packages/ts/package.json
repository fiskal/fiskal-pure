{
  "name": "@fiskal/antifragile",
  "version": "0.1.0",
  "description": "fiskal-antifragile TypeScript package — view/data separation for React",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/firestore": {
      "import": "./dist/adapters/firestore.js",
      "types": "./dist/adapters/firestore.d.ts"
    },
    "./adapters/gun": {
      "import": "./dist/adapters/gun.js",
      "types": "./dist/adapters/gun.d.ts"
    },
    "./adapters/memory": {
      "import": "./dist/adapters/memory.js",
      "types": "./dist/adapters/memory.d.ts"
    },
    "./test": {
      "import": "./dist/test/index.js",
      "types": "./dist/test/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "firebase": ">=10.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
